<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Glasswork.Pages.WorkLogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32" RowDefinitions="Auto,Auto,*,Auto">

        <TextBlock Grid.Row="0" Style="{StaticResource TitleTextBlockStyle}" Text="Work Log" />

        <!-- Week selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,16,0,16">
            <Button Content="◀ Previous" Click="PrevWeek_Click" />
            <TextBlock x:Name="WeekLabel" VerticalAlignment="Center" Style="{StaticResource SubtitleTextBlockStyle}" />
            <Button Content="Next ▶" Click="NextWeek_Click" />
            <Button Content="This Week" Click="ThisWeek_Click" />
        </StackPanel>

        <!-- Log content -->
        <ScrollViewer Grid.Row="2">
            <TextBlock x:Name="LogContent" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
        </ScrollViewer>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
            <Button Content="Copy to Clipboard" Click="Copy_Click" />
            <Button Content="Save to Vault" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Page>
