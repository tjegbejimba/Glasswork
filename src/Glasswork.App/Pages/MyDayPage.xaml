<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Glasswork.Pages.MyDayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32" RowDefinitions="Auto,*,Auto,Auto">

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="My Day" />
            <TextBlock Text="{x:Bind TodayDate}" Opacity="0.6" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Today's tasks -->
        <ListView
            Grid.Row="1"
            x:Name="TodayList"
            ItemsSource="{x:Bind ViewModel.TodayTasks}"
            SelectionMode="None"
            Margin="0,16,0,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,8" ColumnDefinitions="Auto,*,Auto">
                        <CheckBox Grid.Column="0" VerticalAlignment="Center" Click="CompleteTask_Click" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Priority}" FontSize="12" Opacity="0.6" />
                        </StackPanel>
                        <Button Grid.Column="2" Click="RemoveFromDay_Click"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="Remove from My Day">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE711;" FontSize="14" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Suggestions header -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,24,0,8">
            <TextBlock Text="Suggestions" Style="{StaticResource SubtitleTextBlockStyle}" />
            <Button Content="Carry all" Click="CarryAll_Click" />
        </StackPanel>

        <!-- Suggestions list -->
        <ListView Grid.Row="3" ItemsSource="{x:Bind ViewModel.Suggestions}" SelectionMode="None" MaxHeight="200">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,6" ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Status}" FontSize="12" Opacity="0.6" />
                        </StackPanel>
                        <Button Grid.Column="1" Click="AddToDay_Click"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="Add to My Day">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" FontSize="14" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
