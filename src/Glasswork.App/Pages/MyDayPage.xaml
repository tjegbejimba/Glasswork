<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Glasswork.Pages.MyDayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:Glasswork.Converters"
    xmlns:controls="using:Glasswork.Controls"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolVisibilityConverter x:Key="BoolVis" />
        <conv:SubtaskSegmentBrushConverter x:Key="SegBrush" />
        <conv:DueUrgencyBrushConverter x:Key="DueBg" />
        <conv:DueUrgencyForegroundBrushConverter x:Key="DueFg" />
    </Page.Resources>

    <Grid Padding="32" RowDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto">

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="My Day" />
            <TextBlock Text="{x:Bind TodayDate}" Opacity="0.6" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Today's tasks -->
        <ListView
            Grid.Row="1"
            x:Name="TodayList"
            ItemsSource="{x:Bind ViewModel.TodayTasks}"
            SelectionMode="Single"
            IsItemClickEnabled="False"
            Margin="0,16,0,0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,2" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10,8" RowDefinitions="Auto,Auto"
                          DoubleTapped="TaskRow_DoubleTapped"
                          Background="Transparent">
                        <!-- Title row -->
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                            <Grid Grid.Column="0" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,8,0">
                                <CheckBox VerticalAlignment="Center" HorizontalAlignment="Center"
                                          IsChecked="{Binding IsDone, Mode=OneWay}"
                                          Style="{StaticResource CircleCheckBoxStyle}"
                                          IsHitTestVisible="False" IsTabStop="False" />
                                <Button Background="Transparent" BorderThickness="0" Padding="0"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        Click="CompleteTask_Click" />
                            </Grid>
                            <HyperlinkButton Grid.Column="1" Content="{Binding Title}"
                                             Click="OpenTask_Click"
                                             Padding="0" VerticalAlignment="Center"
                                             HorizontalAlignment="Stretch"
                                             HorizontalContentAlignment="Left" />
                            <!-- Priority chip (high/urgent only) -->
                            <Border Grid.Column="2" Style="{StaticResource ChipBorderStyle}"
                                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                    Visibility="{Binding HasPriorityChip, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="{Binding Priority}" Style="{StaticResource ChipTextStyle}" />
                            </Border>
                            <!-- Due chip -->
                            <Border Grid.Column="3" Style="{StaticResource ChipBorderStyle}"
                                    Background="{Binding DueUrgency, Converter={StaticResource DueBg}}"
                                    Visibility="{Binding HasDue, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="{Binding DueChipText}" Style="{StaticResource ChipTextStyle}"
                                           Foreground="{Binding DueUrgency, Converter={StaticResource DueFg}}" />
                            </Border>
                            <Button Grid.Column="4" Click="RemoveFromDay_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,2" VerticalAlignment="Center" Margin="6,0,0,0"
                                    ToolTipService.ToolTip="Remove from My Day">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE711;" FontSize="13" />
                            </Button>
                        </Grid>

                        <!-- Card details (active + not collapsed) -->
                        <StackPanel Grid.Row="1" Spacing="6" Margin="32,6,0,2"
                                    Visibility="{Binding ShowCardDetails, Converter={StaticResource BoolVis}}">
                            <!-- Segmented progress bar (≤12 subtasks) -->
                            <ItemsControl ItemsSource="{Binding Subtasks}"
                                          Visibility="{Binding UseSegmentedBar, Converter={StaticResource BoolVis}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="22" Height="6" CornerRadius="2"
                                                Background="{Binding Converter={StaticResource SegBrush}}"
                                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="0,0,0,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Continuous progress bar (≥13 subtasks) -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                                  Visibility="{Binding UseContinuousBar, Converter={StaticResource BoolVis}}">
                                <ProgressBar Grid.Column="0" Minimum="0" Maximum="1"
                                             Value="{Binding ProgressFraction}" />
                                <TextBlock Grid.Column="1" Text="{Binding ProgressLabel}"
                                           FontSize="11" Opacity="0.65" VerticalAlignment="Center" />
                            </Grid>
                            <!-- Current step -->
                            <Grid ColumnDefinitions="Auto,*"
                                  Visibility="{Binding HasCurrentStep, Converter={StaticResource BoolVis}}">
                                <Border Grid.Column="0" Width="3" Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="1.5" Margin="0,1,8,1" />
                                <TextBlock Grid.Column="1" Text="{Binding CurrentStepText}" FontSize="13" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </Grid>
                            <!-- Blocker -->
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        Visibility="{Binding HasBlocker, Converter={StaticResource BoolVis}}">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7BA;" FontSize="11"
                                          Foreground="#C50F1F" />
                                <TextBlock Text="{Binding FirstBlockerText}" FontSize="12"
                                           Foreground="#C50F1F" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <!-- Blurb -->
                            <TextBlock Text="{Binding BlurbPreview}" FontSize="12" Opacity="0.65"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding HasBlurb, Converter={StaticResource BoolVis}}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state: shown when My Day has no tasks and no flagged subtasks -->
        <controls:EmptyState
            x:Name="EmptyStateView"
            Grid.Row="1"
            Margin="0,16,0,0"
            Glyph="&#xE706;"
            Headline="Today is open."
            Body="Nothing's been pulled into your day yet. Carry over yesterday's unfinished work, or pick something from the Backlog."
            CtaText="Open Backlog"
            CtaClicked="EmptyState_OpenBacklog"
            Visibility="Collapsed" />

        <!-- Flagged subtasks (parents not in My Day, but with at least one subtask flagged today) -->
        <StackPanel x:Name="SubtaskGroupsSection" Grid.Row="2" Margin="0,16,0,0" Visibility="Collapsed">
            <TextBlock Text="Flagged subtasks" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ItemsControl ItemsSource="{x:Bind SubtaskGroups}" Margin="0,8,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="12,8" Margin="0,0,0,8">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding ParentTitle}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding OtherSubtasksLabel}" Opacity="0.55" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Anchors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,Auto" Padding="8,4,0,4">
                                                <HyperlinkButton Grid.Column="0" Content="{Binding DisplayText}"
                                                                 Click="SubtaskAnchor_Click"
                                                                 HorizontalAlignment="Left" Padding="0" />
                                                <Button Grid.Column="1" Click="RemoveSubtaskFromDay_Click"
                                                        Background="Transparent" BorderThickness="0"
                                                        Padding="6" VerticalAlignment="Center"
                                                        ToolTipService.ToolTip="Remove subtask from My Day">
                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE711;" FontSize="12" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Recently Completed (today, was on My Day) -->
        <StackPanel x:Name="RecentlyCompletedHeader" Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,24,0,8" Visibility="Collapsed">
            <TextBlock Text="Recently completed" Style="{StaticResource SubtitleTextBlockStyle}" Opacity="0.75" />
            <TextBlock Text="{x:Bind ViewModel.RecentlyCompletedTasks.Count, Mode=OneWay}" Opacity="0.5" VerticalAlignment="Center" />
        </StackPanel>

        <ListView x:Name="RecentlyCompletedList" Grid.Row="4" Visibility="Collapsed"
                  ItemsSource="{x:Bind ViewModel.RecentlyCompletedTasks}" SelectionMode="None" MaxHeight="200">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,1" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10,6" ColumnDefinitions="Auto,*,Auto,Auto" Background="Transparent" Opacity="0.7">
                        <Grid Grid.Column="0" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,8,0">
                            <CheckBox VerticalAlignment="Center" HorizontalAlignment="Center"
                                      IsChecked="{Binding IsDone, Mode=OneWay}"
                                      Style="{StaticResource CircleCheckBoxStyle}"
                                      IsHitTestVisible="False" IsTabStop="False" />
                            <Button Background="Transparent" BorderThickness="0" Padding="0"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    Click="UncompleteTask_Click"
                                    ToolTipService.ToolTip="Move back to To-do" />
                        </Grid>
                        <HyperlinkButton Grid.Column="1" Content="{Binding Title}"
                                         Click="OpenTask_Click"
                                         Padding="0" VerticalAlignment="Center"
                                         HorizontalAlignment="Stretch"
                                         HorizontalContentAlignment="Left">
                            <HyperlinkButton.Resources>
                                <ResourceDictionary>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                    </Style>
                                </ResourceDictionary>
                            </HyperlinkButton.Resources>
                        </HyperlinkButton>
                        <Border Grid.Column="2" Style="{StaticResource ChipBorderStyle}"
                                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                Visibility="{Binding HasPriorityChip, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="{Binding Priority}" Style="{StaticResource ChipTextStyle}" />
                        </Border>
                        <Border Grid.Column="3" Style="{StaticResource ChipBorderStyle}"
                                Background="{Binding DueUrgency, Converter={StaticResource DueBg}}"
                                Visibility="{Binding HasDue, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="{Binding DueChipText}" Style="{StaticResource ChipTextStyle}"
                                       Foreground="{Binding DueUrgency, Converter={StaticResource DueFg}}" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Suggestions header -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="12" Margin="0,24,0,8">
            <TextBlock Text="Suggestions" Style="{StaticResource SubtitleTextBlockStyle}" />
            <Button Content="Carry all" Click="CarryAll_Click" />
        </StackPanel>

        <!-- Suggestions list (slim — default) -->
        <ListView x:Name="SuggestionsList" Grid.Row="6" ItemsSource="{x:Bind ViewModel.Suggestions}" SelectionMode="None" MaxHeight="200">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,4" ColumnDefinitions="*,Auto">
                        <HyperlinkButton Grid.Column="0" Content="{Binding Title}"
                                         Click="OpenTask_Click"
                                         Padding="0" VerticalAlignment="Center"
                                         HorizontalAlignment="Stretch"
                                         HorizontalContentAlignment="Left" />
                        <Button Grid.Column="1" Click="AddToDay_Click"
                                Background="Transparent" BorderThickness="0"
                                Padding="6" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Add to My Day">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" FontSize="14" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Suggestions list (rich — empty state only) -->
        <ListView x:Name="RichSuggestionsList" Grid.Row="6" Visibility="Collapsed"
                  ItemsSource="{x:Bind ViewModel.Suggestions}" SelectionMode="None" MaxHeight="400">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,2" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10,8" RowDefinitions="Auto,Auto" Background="Transparent">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto">
                            <HyperlinkButton Grid.Column="0" Content="{Binding Title}"
                                             Click="OpenTask_Click"
                                             Padding="0" VerticalAlignment="Center"
                                             HorizontalAlignment="Stretch"
                                             HorizontalContentAlignment="Left" />
                            <Border Grid.Column="1" Style="{StaticResource ChipBorderStyle}"
                                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                    Visibility="{Binding HasPriorityChip, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="{Binding Priority}" Style="{StaticResource ChipTextStyle}" />
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource ChipBorderStyle}"
                                    Background="{Binding DueUrgency, Converter={StaticResource DueBg}}"
                                    Visibility="{Binding HasDue, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="{Binding DueChipText}" Style="{StaticResource ChipTextStyle}"
                                           Foreground="{Binding DueUrgency, Converter={StaticResource DueFg}}" />
                            </Border>
                            <Button Grid.Column="3" Click="AddToDay_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,2" VerticalAlignment="Center" Margin="6,0,0,0"
                                    ToolTipService.ToolTip="Add to My Day">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" FontSize="13" />
                            </Button>
                        </Grid>
                        <StackPanel Grid.Row="1" Spacing="6" Margin="0,6,0,2"
                                    Visibility="{Binding IsActive, Converter={StaticResource BoolVis}}">
                            <ItemsControl ItemsSource="{Binding Subtasks}"
                                          Visibility="{Binding UseSegmentedBar, Converter={StaticResource BoolVis}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="22" Height="6" CornerRadius="2"
                                                Background="{Binding Converter={StaticResource SegBrush}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                                  Visibility="{Binding UseContinuousBar, Converter={StaticResource BoolVis}}">
                                <ProgressBar Grid.Column="0" Minimum="0" Maximum="1" Value="{Binding ProgressFraction}" />
                                <TextBlock Grid.Column="1" Text="{Binding ProgressLabel}"
                                           FontSize="11" Opacity="0.65" VerticalAlignment="Center" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*"
                                  Visibility="{Binding HasCurrentStep, Converter={StaticResource BoolVis}}">
                                <Border Grid.Column="0" Width="3" Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="1.5" Margin="0,1,8,1" />
                                <TextBlock Grid.Column="1" Text="{Binding CurrentStepText}" FontSize="13" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="{Binding BlurbPreview}" FontSize="12" Opacity="0.65"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding HasBlurb, Converter={StaticResource BoolVis}}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
