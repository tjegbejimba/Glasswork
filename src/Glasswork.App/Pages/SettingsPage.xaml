<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Glasswork.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Glasswork.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="40,32,40,32">
        <StackPanel Spacing="24" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock
                Text="Settings"
                Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- Vault Configuration -->
            <StackPanel Spacing="8">
                <TextBlock
                    Text="Vault"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="The folder Glasswork reads tasks from. Switching vaults resets per-task UI state (collapse overrides, etc.)."
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                    <TextBox
                        Grid.Column="0" Grid.Row="0"
                        x:Name="VaultPathBox"
                        Header="Path"
                        IsReadOnly="True"
                        PlaceholderText="(no vault configured)" />
                    <Button
                        Grid.Column="1" Grid.Row="0"
                        x:Name="SwitchVaultButton"
                        Content="Switch…"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,0"
                        Click="SwitchVaultButton_Click" />

                    <TextBlock
                        Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                        x:Name="VaultInfoText"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        TextWrapping="Wrap" />

                    <InfoBar
                        Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2"
                        x:Name="VaultWarningBar"
                        IsOpen="False"
                        IsClosable="True"
                        Severity="Warning" />
                </Grid>
            </StackPanel>

            <!-- Appearance -->
            <StackPanel Spacing="8">
                <TextBlock
                    Text="Appearance"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="Choose the app theme. System follows your Windows personalization setting."
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="ThemeComboBox"
                          Header="Theme"
                          SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="System" Tag="system" />
                    <ComboBoxItem Content="Light" Tag="light" />
                    <ComboBoxItem Content="Dark" Tag="dark" />
                </ComboBox>
            </StackPanel>

            <!-- Azure DevOps -->
            <StackPanel Spacing="8">
                <TextBlock
                    Text="Azure DevOps"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="Base URL used to build links to ADO work items. Leave empty to disable ADO link buttons."
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBox
                    x:Name="AdoBaseUrlBox"
                    Header="Base URL"
                    PlaceholderText="https://dev.azure.com/myorg/myproject"
                    LostFocus="AdoBaseUrlBox_LostFocus" />
                <TextBlock
                    Text="Example: https://dev.azure.com/myorg/myproject — work item links become {baseUrl}/_workitems/edit/{id}"
                    TextWrapping="Wrap"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

