<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Glasswork.Pages.SubtaskDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Subtask"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <ScrollViewer MaxHeight="520">
        <StackPanel Spacing="12" MinWidth="420">

            <TextBox x:Name="TextBox" Header="Title" />

            <ComboBox x:Name="StatusBox" Header="Status" HorizontalAlignment="Stretch"
                      SelectionChanged="StatusBox_SelectionChanged">
                <ComboBoxItem Tag="todo" Content="To Do" />
                <ComboBoxItem Tag="in_progress" Content="In Progress" />
                <ComboBoxItem Tag="blocked" Content="Blocked" />
                <ComboBoxItem Tag="done" Content="Done" />
                <ComboBoxItem Tag="dropped" Content="Dropped" />
            </ComboBox>

            <TextBox x:Name="BlockerBox" Header="Blocker reason"
                     PlaceholderText="What's blocking this?"
                     Visibility="Collapsed" />

            <CalendarDatePicker x:Name="DuePicker" Header="Due date"
                                HorizontalAlignment="Stretch" />

            <TextBox x:Name="AdoBox" Header="ADO work item ID (optional)"
                     PlaceholderText="e.g. 12345" InputScope="Number" />

            <TextBox x:Name="NotesBox" Header="Notes" AcceptsReturn="True"
                     MinHeight="100" TextWrapping="Wrap"
                     PlaceholderText="Additional context for this subtask..." />

            <CheckBox x:Name="MyDayBox" Content="In My Day" />

            <Button x:Name="PromoteButton" Content="Promote to top-level task"
                    Click="PromoteButton_Click"
                    HorizontalAlignment="Stretch" Margin="0,8,0,0" />

            <Button x:Name="DeleteButton" Content="Delete subtask"
                    Click="DeleteButton_Click"
                    HorizontalAlignment="Stretch" />

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
