<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Glasswork.Pages.BacklogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32" RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="Backlog" />

        <!-- Filter bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,16,0,16">
            <ComboBox x:Name="StatusFilter" SelectedIndex="0" SelectionChanged="StatusFilter_Changed" Width="160">
                <ComboBoxItem Tag="all" Content="Active (not done)" />
                <ComboBoxItem Tag="todo" Content="To Do" />
                <ComboBoxItem Tag="in-progress" Content="In Progress" />
                <ComboBoxItem Tag="done" Content="Done" />
            </ComboBox>

            <Button Content="&#xE710;" FontFamily="Segoe Fluent Icons" Click="AddTask_Click" ToolTipService.ToolTip="New task" />
        </StackPanel>

        <!-- Task list -->
        <ListView
            Grid.Row="2"
            x:Name="TaskList"
            ItemsSource="{x:Bind ViewModel.Tasks}"
            SelectedItem="{x:Bind ViewModel.SelectedTask, Mode=TwoWay}"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,8" ColumnDefinitions="Auto,*,Auto,Auto">
                        <!-- Status indicator -->
                        <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{x:Null}" />
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Title and metadata -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Status}" FontSize="12" Opacity="0.6" />
                                <TextBlock Text="{Binding Priority}" FontSize="12" Opacity="0.6" />
                            </StackPanel>
                        </StackPanel>

                        <!-- My Day toggle -->
                        <Button Grid.Column="2" Click="ToggleMyDay_Click"
                                ToolTipService.ToolTip="Toggle My Day"
                                Background="Transparent" BorderThickness="0">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE706;" FontSize="16" />
                        </Button>

                        <!-- Context menu -->
                        <Button Grid.Column="3" Background="Transparent" BorderThickness="0">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE712;" FontSize="16" />
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Mark To Do" Click="SetTodo_Click" />
                                    <MenuFlyoutItem Text="Mark In Progress" Click="SetInProgress_Click" />
                                    <MenuFlyoutItem Text="Mark Done" Click="SetDone_Click" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
