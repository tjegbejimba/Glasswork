<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Glasswork.Pages.FeedbackDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Send Feedback"
    PrimaryButtonText="Submit"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="OnSubmit">

    <StackPanel Spacing="12" MinWidth="400">
        <ComboBox x:Name="CategoryBox" Header="Category" SelectedIndex="0" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="Bug" />
            <ComboBoxItem Content="Feature Request" />
            <ComboBoxItem Content="General Feedback" />
        </ComboBox>

        <TextBox x:Name="TitleBox" Header="Title" PlaceholderText="Brief summary" />

        <TextBox x:Name="BodyBox" Header="Details" PlaceholderText="Describe the issue or idea..."
                 AcceptsReturn="True" TextWrapping="Wrap" Height="120" />

        <InfoBar x:Name="StatusBar" IsOpen="False" />
    </StackPanel>
</ContentDialog>
