<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Glasswork.Pages.AdoImportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Import from Azure DevOps"
    PrimaryButtonText="Import Selected"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False">

    <StackPanel Spacing="12" MinWidth="400">
        <TextBox x:Name="SearchBox" PlaceholderText="Search your assigned work items..."
                 KeyDown="Search_KeyDown" />
        <Button Content="Search" Click="Search_Click" />

        <ProgressRing x:Name="LoadingRing" IsActive="False" Width="32" Height="32" />

        <ListView x:Name="ResultsList" MaxHeight="300"
                  SelectionChanged="Results_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Padding="4">
                        <TextBlock FontWeight="SemiBold">
                            <Run Text="#" /><Run Text="{Binding Id}" />
                            <Run Text=" — " />
                            <Run Text="{Binding Title}" />
                        </TextBlock>
                        <TextBlock Opacity="0.6" FontSize="12">
                            <Run Text="{Binding WorkItemType}" />
                            <Run Text=" | " />
                            <Run Text="{Binding State}" />
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>
