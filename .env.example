# Glasswork Environment Variables
# Copy to your shell profile or set as User environment variables.

# GitHub (optional — enables "Feedback" button to create GitHub issues)
GLASSWORK_GITHUB_TOKEN=      # GitHub PAT with "public_repo" scope

# ADO integration is handled by agents (Copilot CLI, etc.) who read/write
# task files directly in the vault. No PAT needed in the app itself.
